# Server Config
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/kanteen-bites
MONGODB_TEST_URI=mongodb://localhost:27017/kanteen-bites-test

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Admin
ADMIN_EMAIL=admin@kanteenbites.com
ADMIN_PASSWORD=admin123

# Canteen Settings
CANTEEN_OPENING_TIME=07:00
CANTEEN_CLOSING_TIME=21:00
CANTEEN_TIMEZONE=Asia/Kolkata
